# PostgreSQL connection string (server/utils/db.ts).
# With Supabase: use the "postgres" role connection string. On Vercel use the
# pooler (pgBouncer, port 6543).
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# GitHub OAuth App (Settings > Developer settings > OAuth Apps).
# Authorization callback URL must be <your-origin>/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=your-oauth-client-id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=your-oauth-client-secret

# Secret used to encrypt the session cookie. Must be at least 32 characters.
# Generate e.g. with:  openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-32-chars-min

# GitHub login of the single owner (owner-gate). REQUIRED in production —
# without it any GitHub account that passes OAuth gets access.
OWNER_GITHUB=your-github-username

# Shared secret for the n8n webhook (server/api/webhook/jobs.post.ts).
WEBHOOK_SECRET=your-webhook-secret

# Live resume fetch (server/api/resume.get.ts).
# Private GitHub repo holding the resume markdown, as "owner/repo".
RESUME_REPO=your-username/your-private-repo
# Paths to the markdown files inside that repo.
RESUME_PATH_EN=Personal/Resume EN.md
RESUME_PATH_RU=Personal/Resume RU.md
# Token with read access to RESUME_REPO.
GITHUB_TOKEN=your-github-token
