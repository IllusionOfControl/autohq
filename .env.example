# PostgreSQL connection string (server/utils/db.ts).
# With Supabase: use the "postgres" role connection string. On Vercel use the
# pooler (pgBouncer, port 6543).
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# GitHub OAuth App (Settings > Developer settings > OAuth Apps).
# Authorization callback URL must be <your-origin>/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=your-oauth-client-id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=your-oauth-client-secret

# Secret used to encrypt the session cookie. Must be at least 32 characters.
# Generate e.g. with:  openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-32-chars-min

# GitHub login of the single owner (owner-gate). REQUIRED in production —
# without it any GitHub account that passes OAuth gets access.
OWNER_GITHUB=your-github-username

# Shared secret n8n sends in the `x-autohq-token` header to reach the webhook,
# /api/n8n/* and /api/resume (server/utils/secret.ts).
# Also rendered into the {{AUTOHQ_SECRET_TOKEN}} placeholder by npm run n8n:sync.
AUTOHQ_SECRET_TOKEN=your-autohq-secret-token

# Push workflow JSON to n8n via its Public API (npm run n8n:sync).
# N8N_API_KEY: n8n → Settings → n8n API.
# The workflow files are templates: {{APP_URL}} (from NUXT_PUBLIC_APP_URL below)
# and {{AUTOHQ_SECRET_TOKEN}} are substituted from this .env at push time.
N8N_API_URL=https://n8n.example.com
N8N_API_KEY=your-n8n-api-key

# OpenAI-compatible API for the Score and cover-letter nodes in the n8n
# workflows. npm run n8n:sync creates an n8n credential named "AutoHQ OpenAI"
# from these and wires it into the workflows (its id is cached in
# n8n/.credentials.json).
#
# This stack ships a local llama.cpp server (see docker-compose.yml) serving the
# "gemma" model, so the default base URL points at it on the compose network.
# llama.cpp ignores the API key, but n8n:sync requires a non-empty value — any
# placeholder works. To use hosted OpenAI instead, set a real key and
# OPENAI_BASE_URL=https://api.openai.com/v1.
OPENAI_API_KEY=sk-no-key-required
OPENAI_BASE_URL=http://llamacpp:8080/v1

# Telegram alerts (optional). The workflows score every posting and, when a job
# scores at or above your Control-page threshold, fire a Notify Telegram node.
# The bot token itself lives in an n8n credential named "AutoHQ Telegram" that
# you create once by hand (Credentials → Telegram). These two only fill the node:
#   TELEGRAM_CHAT_ID        the chat/channel to message (yourself, a group, etc.)
#   TELEGRAM_CREDENTIAL_ID  optional — paste the "AutoHQ Telegram" credential id
#                           to auto-link it on sync; leave blank to link it once
#                           in the n8n UI. Leave both blank to skip Telegram.
TELEGRAM_CHAT_ID=
TELEGRAM_CREDENTIAL_ID=

# Set to "true" to show sample jobs on the Jobs page instead of querying the DB
# (handy for local dev / demos without a database). Default: false.
NUXT_PUBLIC_USE_SAMPLE_DATA=false

# Control page links (all optional, shown only if set):
# n8n instance URL, Telegram bot handle, and the public app origin used to
# build the displayed webhook URL (falls back to the current origin).
NUXT_PUBLIC_N8N_URL=https://n8n.example.com
NUXT_PUBLIC_TELEGRAM_BOT=@your_bot
NUXT_PUBLIC_APP_URL=https://your-app.example.com

# HH.ru OAuth (server/utils/hhAuth.ts). Tokens are stored in the DB
# (provider_auth table); only these client credentials live here. The values
# below are the HH Android app's client — its consent redirects to
# hhandroid://oauthresponse?token=<CODE>, so authorization is manual-paste:
# open the authorize URL from the Control page, copy <CODE>, paste it back.
HH_CLIENT_ID=your-hh-client-id
HH_CLIENT_SECRET=your-hh-client-secret

# Live resume fetch (server/api/resume.get.ts).
# Private GitHub repo holding the resume markdown, as "owner/repo".
RESUME_REPO=your-username/your-private-repo
# Paths to the markdown files inside that repo.
RESUME_PATH_EN=Personal/Resume EN.md
RESUME_PATH_RU=Personal/Resume RU.md
# Token with read access to RESUME_REPO.
GITHUB_TOKEN=your-github-token
