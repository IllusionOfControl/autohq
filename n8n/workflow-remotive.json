{
  "name": "AutoHQ — Remotive Job Search",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * 1-5"
            }
          ]
        }
      },
      "id": "cron-rem",
      "name": "Every weekday 9:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [
        240,
        300
      ],
      "typeVersion": 1.2
    },
    {
      "parameters": {
        "url": "{{APP_URL}}/api/resume?lang=both",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-autohq-token",
              "value": "{{AUTOHQ_SECRET_TOKEN}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "get-resume",
      "name": "Get Resume",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://remotive.com/api/remote-jobs",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "category",
              "value": "software-dev"
            },
            {
              "name": "search",
              "value": "vue OR nuxt OR frontend"
            },
            {
              "name": "limit",
              "value": "100"
            }
          ]
        },
        "options": {}
      },
      "id": "http-remotive",
      "name": "Fetch Remotive",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        640,
        300
      ],
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "fieldToSplitOut": "jobs",
        "options": {}
      },
      "id": "split-rem",
      "name": "Split Jobs",
      "type": "n8n-nodes-base.splitOut",
      "position": [
        840,
        300
      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\nreturn {\n  title: item.title,\n  company: item.company_name,\n  url: item.url,\n  location: item.candidate_required_location || 'Worldwide',\n  remote: true,\n  status: 'new',\n  fit_score: null,\n  salary_min: null,\n  salary_max: null,\n  source: 'remotive',\n  external_id: String(item.id),\n  description: ((item.description || '') + '').replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 1500),\n  notes: `Source: Remotive | Tags: ${(item.tags || []).join(', ')}`\n};"
      },
      "id": "map-rem",
      "name": "Map to AutoHQ format",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        300
      ]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini",
          "cachedResultName": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "={{>score}}",
              "role": "user"
            }
          ]
        },
        "options": {}
      },
      "id": "openai-score-rem",
      "name": "OpenAI Score",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        1220,
        300
      ],
      "credentials": {
        "openAiApi": {
          "id": "{{OPENAI_CREDENTIAL_ID}}",
          "name": "AutoHQ OpenAI"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const job = $('Map to AutoHQ format').item.json;\nconst raw = $input.item.json;\nlet text = '';\ntry { text = (raw.message?.content ?? raw.content ?? raw.text ?? raw.choices?.[0]?.message?.content ?? '').toString(); } catch (e) {}\nlet score = null;\nlet reason = '';\ntry {\n  const parsed = JSON.parse((text.match(/\\{[\\s\\S]*\\}/) || [text])[0]);\n  score = Number(parsed.score);\n  reason = (parsed.reason || '').toString().trim();\n} catch (e) {\n  const m = text.match(/\\d{1,3}/);\n  if (m) score = Number(m[0]);\n}\nscore = Number.isFinite(score) ? Math.max(0, Math.min(100, Math.round(score))) : null;\nreturn { ...job, fit_score: score, score_reason: reason || null };"
      },
      "id": "parse-score-rem",
      "name": "Parse Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        300
      ]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini",
          "cachedResultName": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "={{>cover-letter}}",
              "role": "user"
            }
          ]
        },
        "options": {}
      },
      "id": "openai-cover-rem",
      "name": "OpenAI Cover Letter",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        1580,
        160
      ],
      "credentials": {
        "openAiApi": {
          "id": "{{OPENAI_CREDENTIAL_ID}}",
          "name": "AutoHQ OpenAI"
        }
      }
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineByPosition",
        "options": {}
      },
      "id": "merge-rem",
      "name": "Combine Job + Letter",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1760,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Input is the Parse Score row merged (by position) with the OpenAI response, so\n// both are present on $json — nothing from Parse Score is lost. Pull the letter\n// out of the model response, drop the response fields, keep the job row.\nconst { message, content, text, choices, index, finish_reason, role, ...job } = $input.item.json;\nlet cover_letter = '';\ntry {\n  cover_letter = (message?.content ?? content ?? text ?? choices?.[0]?.message?.content ?? '').toString().trim();\n} catch (e) { /* leave empty on any parse issue */ }\nreturn { ...job, cover_letter };"
      },
      "id": "assemble-rem",
      "name": "Assemble",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1940,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{APP_URL}}/api/webhook/jobs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-autohq-token",
              "value": "{{AUTOHQ_SECRET_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "post-rem",
      "name": "Send to AutoHQ",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2120,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "tg-notify",
              "leftValue": "={{ $json.telegram_notify }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "tg-gate-rem",
      "name": "Telegram Gate",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2300,
        300
      ]
    },
    {
      "parameters": {
        "chatId": "{{TELEGRAM_CHAT_ID}}",
        "text": "=🎯 {{ $('Assemble').item.json.fit_score }}% — {{ $('Assemble').item.json.title }}\n🏢 {{ $('Assemble').item.json.company }}\n📍 {{ $('Assemble').item.json.location || '—' }}\n🔗 {{ $('Assemble').item.json.url }}\n\n{{ $('Assemble').item.json.score_reason || '' }}",
        "additionalFields": {}
      },
      "id": "tg-notify-rem",
      "name": "Notify Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        2480,
        200
      ],
      "credentials": {
        "telegramApi": {
          "id": "{{TELEGRAM_CREDENTIAL_ID}}",
          "name": "AutoHQ Telegram"
        }
      }
    }
  ],
